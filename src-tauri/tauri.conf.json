{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clawset-desktop",
  "version": "0.2.2",
  "identifier": "ai.openclaw.clawsetdesktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clawset Desktop",
        "width": 1240,
        "height": 920,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ]
  }
}
